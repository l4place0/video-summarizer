# LLM Provider Keys
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# LLM defaults
LLM_PROVIDER=claude

# Claude settings
CLAUDE_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=

# OpenAI settings (compatible with any OpenAI-format API)
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Whisper
WHISPER_MODEL=base

# Server
HOST=0.0.0.0
PORT=8000
